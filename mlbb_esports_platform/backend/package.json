{
  "name": "mlbb-esports-platform",
  "version": "1.0.0",
  "description": "Professional MLBB Esports Platform with Microservice Architecture",
  "private": true,
  "workspaces": {
    "packages": [
      "services/*",
      "common/*"
    ]
  },
  "scripts": {
    "dev": "docker-compose up --build",
    "prod": "kubectl apply -f k8s/",
    "build:services": "npm run build --workspace=@esports/core",
    "test": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json}\""
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}